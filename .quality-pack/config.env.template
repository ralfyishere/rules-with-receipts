# .quality-pack/config.env — project-local quality-pack settings.
# Sourced by scripts/hygiene-gate.sh, scripts/security-scan.sh, and the
# closeout tooling. This file is YOURS: the installer creates it once and
# never overwrites it. All values optional; safe defaults apply when unset.

# GitHub owner for repo-surface checks (webhooks/keys/collaborators).
# Empty = skip the GitHub-surface section of the scan.
QP_GH_OWNER=""

# Space-separated git identities allowed in this repo's history.
# Empty = whatever `git config user.email` is at scan time.
QP_ALLOWED_GIT_EMAILS=""

# Hygiene gate: 1 = block public-boundary commands without a fresh scan pass
# (recommended); 0 = log-only (the gate never blocks).
QP_HOOKS_ENFORCED=1

# Minutes a clean security-scan pass keeps the gate open.
QP_GATE_TTL_MIN=60

# Extra extended-regex alternations appended to the scan patterns, e.g.
# QP_EXTRA_SECRET_PATTERNS="mycorp_api_[a-z0-9]{32}"
QP_EXTRA_SECRET_PATTERNS=""
QP_EXTRA_LEAK_PATTERNS=""

# Public-mirror settings (only if this project maintains a public mirror).
# QP_MIRROR_TARGET: path to a clone of the mirror; empty = no mirror.
# QP_MIRROR_EXCLUDE: space-separated paths never copied to the mirror.
QP_MIRROR_TARGET=""
QP_MIRROR_EXCLUDE=""

# Where project-specific business/user context lives.
QP_CONTEXT_DIR="claude-context"
